{
  "expo": {
    "name": "workout-rpg",
    "slug": "workout-rpg",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "predictiveBackGestureEnabled": false
    },
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "plugins": [
      [
        "expo-asset",
        {
          "assets": [
            "assets/workout.db"
          ]
        }
      ],
      "expo-sqlite"
    ]
  }
}
